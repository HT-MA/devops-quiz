{
  "name": "devops-quiz",
  "version": "1.0.0",
  "description": "DevOps工程师选择题刷题 - 桌面版",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "vite:dev": "vite",
    "electron:dev": "electron ."
  },
  "build": {
    "appId": "com.devops.quiz",
    "productName": "DevOps刷题",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
